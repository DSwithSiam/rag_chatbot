# OpenAI credentials
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# API behavior
MAX_CHUNK_SIZE=900
CHUNK_OVERLAP=120
TOP_K=4
MIN_SIMILARITY=0.40
MAX_HISTORY_TURNS=8

# Paths
DOCUMENTS_DIR=data/documents
INDEX_DIR=data/index

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
